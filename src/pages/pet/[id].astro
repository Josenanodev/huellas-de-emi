---
import Layout from "../../layouts/Layout.astro";
import { getPetById } from "../../lib/pets";
import { formatPetAge } from "../../utils/petAge";
import type { Pet } from "../../types";

const { id } = Astro.params;

let pet: Pet | null = null;
let error: string | null = null;

try {
  pet = await getPetById(id);
  if (!pet) {
    error = "Mascota no encontrada";
  }
} catch (e) {
  error = "Error al cargar la mascota";
}

const whatsappMessage = pet
  ? encodeURIComponent(
      `Hola, me gustaría obtener más información sobre la adopción de ${pet.name}.`,
    )
  : "";

const speciesLabel = pet?.species === "cat" ? "Gatito" : "Perrito";
const pageDescription = pet
  ? `${pet.name} es ${speciesLabel.toLowerCase()} en adopción. ${pet.description.slice(0, 135)}${pet.description.length > 135 ? "..." : ""}`
  : "Conoce esta mascota en adopción de Huellas de Emi.";
const petImage = pet?.images.find((image) => image.startsWith("http") || image.startsWith("/"));
const socialImage = petImage || "/images/og-cover.png";
const galleryImages = pet?.images.length ? pet.images : ["/images/default-dog.svg"];
---

<Layout
  title={pet ? `${pet.name} en adopción` : "Mascota"}
  description={pageDescription}
  image={socialImage}
>
  <div class="container page-stack">
    {error ? (
      <div class="error" role="alert">{error}</div>
    ) : pet ? (
      <article class={`dog-detail species-${pet.species}`}>
        <div class="dog-detail-header">
          <div class="pet-gallery" data-pet-gallery data-gallery-pet={pet.name}>
            <div class="pet-gallery-main">
              <img
                src={galleryImages[0]}
                alt={pet.name}
                class="pet-gallery-image"
                data-gallery-main
                fetchpriority="high"
                decoding="async"
              />
              {galleryImages.length > 1 && (
                <span class="pet-gallery-count" data-gallery-count>
                  1 / {galleryImages.length}
                </span>
              )}
            </div>

            {galleryImages.length > 1 && (
              <div class="pet-gallery-thumbs" aria-label={`Fotos de ${pet.name}`}>
                {galleryImages.map((image: string, index: number) => (
                  <button
                    type="button"
                    class={`pet-gallery-thumb${index === 0 ? " active" : ""}`}
                    data-gallery-thumb
                    data-gallery-image={image}
                    data-gallery-index={index}
                    aria-label={`Ver foto ${index + 1} de ${pet.name}`}
                    aria-pressed={index === 0 ? "true" : "false"}
                  >
                    <img
                      src={image}
                      alt=""
                      loading={index === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>

          <div class="dog-detail-info">
            <p class="section-kicker">Historia de adopción</p>
            <p class="species-label">{speciesLabel}</p>
            <h1>{pet.name}</h1>
            <span class={`dog-status status-${pet.status}`}>
              {pet.status === "available" && "Disponible"}
              {pet.status === "adopted" && "Adoptado"}
              {pet.status === "in_treatment" && "En tratamiento"}
              {pet.status === "reserved" && "Reservado"}
            </span>

            <div class="info-grid">
              <div class="info-item info-breed">
                <strong>Raza</strong>
                <span>{pet.breed}</span>
              </div>
              <div class="info-item info-age">
                <strong>Edad</strong>
                <span>{formatPetAge(pet)}</span>
              </div>
              <div class="info-item info-gender">
                <strong>Género</strong>
                <span>{pet.gender === "male" ? "Macho" : "Hembra"}</span>
              </div>
              <div class="info-item info-size">
                <strong>Tamaño</strong>
                <span>
                  {pet.size === "small" && "Pequeño"}
                  {pet.size === "medium" && "Mediano"}
                  {pet.size === "large" && "Grande"}
                </span>
              </div>
              <div class="info-item info-vaccine">
                <strong>Vacunado</strong>
                <span>{pet.vaccinated ? "Sí" : "No"}</span>
              </div>
              <div class="info-item info-care">
                <strong>Esterilizado</strong>
                <span>{pet.sterilized ? "Sí" : "No"}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="detail-content">
          <section class="detail-section">
            <h2>Sobre {pet.name}</h2>
            <p>{pet.description}</p>
          </section>

          {pet.personality && (
            <section class="detail-section">
              <h2>Personalidad</h2>
              <p>{pet.personality}</p>
            </section>
          )}

          {pet.healthConditions.length > 0 && (
            <section class="detail-section">
              <h2>Condiciones de salud</h2>
              <ul class="soft-list">
                {pet.healthConditions.map((condition: string) => (
                  <li>{condition}</li>
                ))}
              </ul>
            </section>
          )}

          {pet.specialCare && (
            <section class="detail-section">
              <h2>Cuidados especiales</h2>
              <p>{pet.specialCare}</p>
            </section>
          )}
        </div>

        {pet.status === "available" && (
          <section class="contact-section">
            <div>
              <p class="section-kicker">Adopción</p>
              <h2>¿Te gustaría adoptar a {pet.name}?</h2>
              <p>Escríbenos por WhatsApp y te contamos más sobre su proceso.</p>
            </div>
            <a
              href={`https://wa.me/523313296314?text=${whatsappMessage}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn whatsapp-btn"
            >
              Enviar WhatsApp
            </a>
          </section>
        )}
      </article>
    ) : null}

    <div class="back-link">
      <a href="/" class="btn btn-secondary">Volver al catálogo</a>
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>("[data-pet-gallery]").forEach((gallery) => {
    const mainImage = gallery.querySelector<HTMLImageElement>("[data-gallery-main]");
    const count = gallery.querySelector<HTMLElement>("[data-gallery-count]");
    const thumbs = Array.from(
      gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-thumb]"),
    );

    if (!mainImage || thumbs.length === 0) return;

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const image = thumb.dataset.galleryImage;
        const index = Number(thumb.dataset.galleryIndex || 0);
        if (!image) return;

        mainImage.src = image;
        mainImage.alt = `Foto ${index + 1} de ${gallery.dataset.galleryPet || "la mascota"}`;
        count && (count.textContent = `${index + 1} / ${thumbs.length}`);

        thumbs.forEach((item) => {
          const isActive = item === thumb;
          item.classList.toggle("active", isActive);
          item.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
      });
    });
  });
</script>
