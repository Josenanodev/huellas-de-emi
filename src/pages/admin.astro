---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Admin" noindex={true}>
  <div class="container page-stack">
    <div class="admin-container">
      <div id="login-section">
        <div class="login-card">
          <img src="/images/heart-paw.svg" alt="" class="login-mark" aria-hidden="true" />
          <p class="section-kicker">Huellas de Emi</p>
          <h1>Panel de Administración</h1>
          <p class="login-copy">Entra para agregar mascotas, actualizar historias y mantener el catálogo bonito.</p>

          <div class="form-group">
            <label for="admin-password">Contraseña de administrador</label>
            <input
              type="password"
              id="admin-password"
              placeholder="Escribe la contraseña"
              autocomplete="current-password"
            />
          </div>

          <button id="login-btn" class="btn login-btn">Iniciar sesión</button>
          <div id="auth-message"></div>
        </div>
      </div>

      <div id="admin-panel" style="display: none;">
        <div class="admin-header">
          <div>
            <p class="section-kicker">Catálogo</p>
            <h1>Gestionar mascotas</h1>
          </div>
          <button id="logout-btn" class="btn btn-secondary">Cerrar Sesión</button>
        </div>

        <div id="admin-message"></div>

        <div class="admin-menu" role="tablist" aria-label="Acciones de administración">
          <button type="button" class="admin-menu-btn active" id="manage-dogs-tab">
            Gestionar existentes
          </button>
          <button type="button" class="admin-menu-btn" id="add-dog-tab">
            Agregar mascota
          </button>
        </div>

        <div id="dog-form-section" style="display: none;">
          <h2 id="form-title">Agregar nueva mascota</h2>
          <form id="dog-form">
            <input type="hidden" id="dog-id" />

            <div class="form-group">
              <label for="species">Especie *</label>
              <select id="species" name="species" required>
                <option value="dog">Perrito</option>
                <option value="cat">Gatito</option>
              </select>
            </div>

            <div class="form-group">
              <label for="name">Nombre *</label>
              <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
              <label for="breed">Raza *</label>
              <input type="text" id="breed" name="breed" required />
            </div>

            <div class="form-group">
              <label for="approximateBirthDate">Fecha aproximada de nacimiento *</label>
              <input type="date" id="approximateBirthDate" name="approximateBirthDate" required />
            </div>

            <div class="form-group">
              <label for="gender">Género *</label>
              <select id="gender" name="gender" required>
                <option value="">Seleccionar...</option>
                <option value="male">Macho</option>
                <option value="female">Hembra</option>
              </select>
            </div>

            <div class="form-group">
              <label for="size">Tamaño *</label>
              <select id="size" name="size" required>
                <option value="">Seleccionar...</option>
                <option value="small">Pequeño</option>
                <option value="medium">Mediano</option>
                <option value="large">Grande</option>
              </select>
            </div>

            <div class="form-group">
              <label for="status">Estado *</label>
              <select id="status" name="status" required>
                <option value="available">Disponible</option>
                <option value="reserved">Reservado</option>
                <option value="in_treatment">En Tratamiento</option>
                <option value="adopted">Adoptado</option>
              </select>
            </div>

            <div class="form-group">
              <label for="description">Descripción *</label>
              <textarea id="description" name="description" required></textarea>
            </div>

            <div class="form-group">
              <label for="personality">Personalidad</label>
              <textarea id="personality" name="personality"></textarea>
            </div>

            <div class="form-group">
              <label for="specialCare">Cuidados Especiales</label>
              <textarea id="specialCare" name="specialCare"></textarea>
            </div>

            <div class="form-group">
              <label for="healthConditions"
                >Condiciones de Salud (separadas por coma)</label
              >
              <input
                type="text"
                id="healthConditions"
                name="healthConditions"
                placeholder="Ej: Displasia, Artritis"
              />
            </div>

            <div class="form-group-row">
              <label>
                <input type="checkbox" id="vaccinated" name="vaccinated" />
                Vacunado
              </label>
            </div>

            <div class="form-group-row">
              <label>
                <input type="checkbox" id="sterilized" name="sterilized" />
                Esterilizado
              </label>
            </div>

            <div class="form-group">
              <label for="images">URLs de Imágenes (separadas por coma)</label>
              <input
                type="text"
                id="images"
                name="images"
                placeholder="Ej: http://ejemplo.com/img1.jpg, http://ejemplo.com/img2.jpg"
              />
            </div>

            <div class="form-group" id="existing-images-section" style="display: none;">
              <label>Imágenes Actuales</label>
              <div
                id="existing-images"
                style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.5rem; margin-top: 0.5rem;"
              >
              </div>
              <small
                id="delete-images-legend"
                style="display: none; margin-top: 0.5rem; color: var(--primary-dark);"
              >
                Guarde los cambios para eliminar imagenes
              </small>
            </div>

            <div class="form-group">
              <label for="image-files">O Subir Imágenes desde tu Computadora</label>
              <input
                type="file"
                id="image-files"
                accept="image/jpeg,image/jpg,image/png,image/webp"
                multiple
              />
              <small
                style="display: block; margin-top: 0.5rem; color: var(--primary-dark);"
              >
                Formatos permitidos: JPG, PNG, WebP. Máximo 6 imágenes; se optimizan automáticamente antes de guardar.
              </small>
              <div
                id="image-preview"
                style="display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 0.5rem; margin-top: 1rem;"
              >
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn" id="submit-btn">Guardar</button>
              <button type="button" class="btn btn-secondary" id="cancel-btn"
                >Cancelar</button
              >
            </div>
          </form>
        </div>

        <div class="admin-list-section" id="admin-list-section">
          <h2>Mascotas registradas</h2>
          <div class="admin-list-tools" aria-label="Filtros de mascotas">
            <input type="search" id="admin-search" placeholder="Buscar por nombre o raza" />
            <select id="admin-species-filter">
              <option value="all">Todas las especies</option>
              <option value="dog">Perritos</option>
              <option value="cat">Gatitos</option>
            </select>
            <select id="admin-status-filter">
              <option value="all">Todos los estados</option>
              <option value="available">Disponibles</option>
              <option value="reserved">Reservados</option>
              <option value="in_treatment">En tratamiento</option>
              <option value="adopted">Adoptados</option>
            </select>
          </div>
          <ul class="dogs-list" id="dogs-list">
            <!-- Pets will be loaded here -->
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div id="error-modal" class="modal" role="alertdialog" aria-modal="true" aria-labelledby="error-modal-title" hidden>
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <span class="modal-icon" aria-hidden="true">!</span>
        <h2 id="error-modal-title" class="modal-title"></h2>
      </div>
      <p id="error-modal-message" class="modal-message"></p>
      <ul id="error-modal-details" class="modal-details"></ul>
      <div class="modal-actions">
        <button type="button" class="btn" id="error-modal-close">Entendido</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  import {
    createNetworkError,
    parseApiError,
    validateImageFiles,
    validateImageUrls,
    validateRequiredFields,
    type MascotFormError,
  } from "../utils/mascotFormErrors";

  let adminPassword = "";

  const loginSection = document.getElementById("login-section");
  const adminPanel = document.getElementById("admin-panel");
  const loginBtn = document.getElementById("login-btn");
  const logoutBtn = document.getElementById("logout-btn");
  const passwordInput = document.getElementById("admin-password") as HTMLInputElement;
  const authMessage = document.getElementById("auth-message");
  const adminMessage = document.getElementById("admin-message");
  const addDogTab = document.getElementById("add-dog-tab");
  const manageDogsTab = document.getElementById("manage-dogs-tab");
  const dogFormSection = document.getElementById("dog-form-section");
  const adminListSection = document.getElementById("admin-list-section");
  const dogForm = document.getElementById("dog-form") as HTMLFormElement;
  const dogsList = document.getElementById("dogs-list");
  const adminSearch = document.getElementById("admin-search") as HTMLInputElement | null;
  const adminSpeciesFilter = document.getElementById("admin-species-filter") as HTMLSelectElement | null;
  const adminStatusFilter = document.getElementById("admin-status-filter") as HTMLSelectElement | null;
  const formTitle = document.getElementById("form-title");
  const dogIdInput = document.getElementById("dog-id") as HTMLInputElement;
  const cancelBtn = document.getElementById("cancel-btn");
  const imageFilesInput = document.getElementById("image-files") as HTMLInputElement;
  const imagePreview = document.getElementById("image-preview");
  const existingImagesSection = document.getElementById("existing-images-section");
  const existingImagesContainer = document.getElementById("existing-images");
  const deleteImagesLegend = document.getElementById("delete-images-legend");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const errorModal = document.getElementById("error-modal");
  const errorModalTitle = document.getElementById("error-modal-title");
  const errorModalMessage = document.getElementById("error-modal-message");
  const errorModalDetails = document.getElementById("error-modal-details");
  const errorModalCloseBtn = document.getElementById("error-modal-close");
  
  let currentDogImages: string[] = [];
  let pendingImageDeletes = new Set<string>();
  let selectedCover: { type: "existing"; value: string } | { type: "upload"; index: number } | null = null;
  let allPets: any[] = [];
  const MAX_IMAGE_COUNT = 6;
  const MAX_IMAGE_DIMENSION = 1280;
  const IMAGE_QUALITY = 0.72;
  const MAX_STORED_IMAGE_CHARS = 450 * 1024;

  function setButtonLoading(
    button: HTMLButtonElement | null | undefined,
    isLoading: boolean,
    loadingText = "Cargando...",
  ) {
    if (!button) return;

    if (isLoading) {
      button.dataset.idleText ||= button.textContent || "";
      button.disabled = true;
      button.classList.add("is-loading");
      button.textContent = loadingText;
    } else {
      button.disabled = false;
      button.classList.remove("is-loading");
      button.textContent = button.dataset.idleText || button.textContent || "";
      delete button.dataset.idleText;
    }
  }

  function setListFiltersDisabled(isDisabled: boolean) {
    adminSearch && (adminSearch.disabled = isDisabled);
    adminSpeciesFilter && (adminSpeciesFilter.disabled = isDisabled);
    adminStatusFilter && (adminStatusFilter.disabled = isDisabled);
    manageDogsTab && ((manageDogsTab as HTMLButtonElement).disabled = isDisabled);
    addDogTab && ((addDogTab as HTMLButtonElement).disabled = isDisabled);
  }

  function renderListLoading(message: string) {
    if (!dogsList) return;

    const item = document.createElement("li");
    item.className = "admin-loading-row";
    item.textContent = message;
    dogsList.replaceChildren(item);
  }

  function getAuthHeaders(withJson = false): Record<string, string> {
    return {
      ...(withJson ? { "Content-Type": "application/json" } : {}),
      "X-Admin-Password": adminPassword,
    };
  }

  function parseCommaSeparated(value: string): string[] {
    return value
      .split(",")
      .map((item) => item.trim())
      .filter((item) => item);
  }

  function formatDateInput(value?: string | Date | null): string {
    if (!value) return "";

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "";

    return date.toISOString().slice(0, 10);
  }

  function estimateBirthDateFromAge(age?: number): string {
    if (typeof age !== "number" || Number.isNaN(age)) return "";

    const date = new Date();
    date.setFullYear(date.getFullYear() - Math.max(age, 0));
    return formatDateInput(date);
  }

  function createFormError(
    code: MascotFormError["code"],
    title: string,
    message: string,
    details: string[],
  ): MascotFormError {
    return { code, title, message, details };
  }

  function canvasToBlob(
    canvas: HTMLCanvasElement,
    type: string,
    quality: number,
  ): Promise<Blob | null> {
    return new Promise((resolve) => canvas.toBlob(resolve, type, quality));
  }

  function loadImageSource(src: string): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const image = new Image();
      image.onload = () => resolve(image);
      image.onerror = () => reject(new Error("No se pudo leer la imagen"));
      image.src = src;
    });
  }

  async function blobToDataUrl(blob: Blob): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = () => reject(new Error("No se pudo convertir la imagen"));
      reader.readAsDataURL(blob);
    });
  }

  async function optimizeImageSource(source: File | string): Promise<string> {
    const sourceUrl = typeof source === "string" ? source : URL.createObjectURL(source);

    try {
      const image = await loadImageSource(sourceUrl);
      const scale = Math.min(1, MAX_IMAGE_DIMENSION / Math.max(image.naturalWidth, image.naturalHeight));
      const width = Math.max(1, Math.round(image.naturalWidth * scale));
      const height = Math.max(1, Math.round(image.naturalHeight * scale));
      const canvas = document.createElement("canvas");
      canvas.width = width;
      canvas.height = height;

      const context = canvas.getContext("2d");
      if (!context) throw new Error("No se pudo preparar la imagen");

      context.drawImage(image, 0, 0, width, height);

      const blob =
        (await canvasToBlob(canvas, "image/webp", IMAGE_QUALITY)) ||
        (await canvasToBlob(canvas, "image/jpeg", IMAGE_QUALITY));

      if (!blob) throw new Error("No se pudo optimizar la imagen");

      const dataUrl = await blobToDataUrl(blob);
      if (dataUrl.length > MAX_STORED_IMAGE_CHARS) {
        throw createFormError(
          "file_too_large",
          "Imagen demasiado pesada",
          "Una imagen sigue pesando demasiado después de optimizarla.",
          ["Intenta recortarla o usar una foto con menor resolución."],
        );
      }

      return dataUrl;
    } finally {
      if (typeof source !== "string") {
        URL.revokeObjectURL(sourceUrl);
      }
    }
  }

  function showAdminView(view: "add" | "manage") {
    const isAddView = view === "add";

    if (dogFormSection) dogFormSection.style.display = isAddView ? "block" : "none";
    if (adminListSection) adminListSection.style.display = isAddView ? "none" : "block";
    addDogTab?.classList.toggle("active", isAddView);
    manageDogsTab?.classList.toggle("active", !isAddView);
  }

  function getSpeciesLabel(species = "dog") {
    return species === "cat" ? "Gatito" : "Perrito";
  }

  function getStatusLabel(status: string) {
    return status === "available"
      ? "Disponible"
      : status === "adopted"
        ? "Adoptado"
        : status === "in_treatment"
          ? "En Tratamiento"
          : "Reservado";
  }

  function getFilteredPets() {
    const search = adminSearch?.value.trim().toLowerCase() || "";
    const species = adminSpeciesFilter?.value || "all";
    const status = adminStatusFilter?.value || "all";

    return allPets.filter((pet) => {
      const petSpecies = pet.species || "dog";
      const matchesSpecies = species === "all" || petSpecies === species;
      const matchesStatus = status === "all" || pet.status === status;
      const matchesSearch =
        !search ||
        `${pet.name || ""} ${pet.breed || ""}`.toLowerCase().includes(search);

      return matchesSpecies && matchesStatus && matchesSearch;
    });
  }

  function resetDogForm() {
    dogForm.reset();
    dogIdInput.value = "";
    currentDogImages = [];
    pendingImageDeletes = new Set();
    selectedCover = null;
    if (imagePreview) imagePreview.innerHTML = "";
    if (existingImagesSection) existingImagesSection.style.display = "none";
    if (existingImagesContainer) existingImagesContainer.innerHTML = "";
    if (deleteImagesLegend) deleteImagesLegend.style.display = "none";
    if (formTitle) formTitle.textContent = "Agregar nueva mascota";
  }

  function renderExistingImages() {
    if (!existingImagesSection || !existingImagesContainer) return;

    existingImagesContainer.innerHTML = "";

    if (currentDogImages.length === 0) {
      existingImagesSection.style.display = "none";
      if (deleteImagesLegend) deleteImagesLegend.style.display = "none";
      return;
    }

    existingImagesSection.style.display = "block";
    const defaultCoverImage = currentDogImages.find((imageUrl) => !pendingImageDeletes.has(imageUrl));

    currentDogImages.forEach((imageUrl: string, index: number) => {
      const isPendingDelete = pendingImageDeletes.has(imageUrl);
      const isCover =
        !isPendingDelete &&
        (selectedCover?.type === "existing"
          ? selectedCover.value === imageUrl
          : !selectedCover && imageUrl === defaultCoverImage);

      const imageWrapper = document.createElement("div");
      imageWrapper.style.position = "relative";
      imageWrapper.style.border = "2px solid var(--border)";
      imageWrapper.style.borderRadius = "4px";
      imageWrapper.style.overflow = "hidden";
      imageWrapper.style.background = "var(--surface-soft)";

      const img = document.createElement("img");
      img.src = imageUrl;
      img.style.width = "100%";
      img.style.height = "120px";
      img.style.objectFit = "cover";
      img.style.display = "block";
      img.style.filter = isPendingDelete ? "grayscale(100%)" : "none";

      const deleteBtn = document.createElement("button");
      deleteBtn.textContent = "×";
      deleteBtn.type = "button";
      deleteBtn.style.position = "absolute";
      deleteBtn.style.top = "4px";
      deleteBtn.style.right = "4px";
      deleteBtn.style.background = "#c33";
      deleteBtn.style.color = "white";
      deleteBtn.style.border = "none";
      deleteBtn.style.borderRadius = "50%";
      deleteBtn.style.width = "24px";
      deleteBtn.style.height = "24px";
      deleteBtn.style.cursor = "pointer";
      deleteBtn.style.fontSize = "18px";
      deleteBtn.style.lineHeight = "1";
      deleteBtn.style.display = "flex";
      deleteBtn.style.alignItems = "center";
      deleteBtn.style.justifyContent = "center";
      deleteBtn.style.zIndex = "2";
      deleteBtn.style.opacity = isPendingDelete ? "0" : "1";
      deleteBtn.style.pointerEvents = isPendingDelete ? "none" : "auto";

      deleteBtn.addEventListener("click", () => {
        pendingImageDeletes.add(imageUrl);
        if (selectedCover?.type === "existing" && selectedCover.value === imageUrl) {
          selectedCover = null;
        }
        renderExistingImages();
      });

      const coverBtn = document.createElement("button");
      coverBtn.type = "button";
      coverBtn.textContent = isCover ? "Portada" : "Usar portada";
      coverBtn.style.position = "absolute";
      coverBtn.style.left = "6px";
      coverBtn.style.bottom = "6px";
      coverBtn.style.zIndex = "2";
      coverBtn.style.padding = "0.25rem 0.45rem";
      coverBtn.style.border = "1px solid rgba(255, 255, 255, 0.7)";
      coverBtn.style.borderRadius = "999px";
      coverBtn.style.fontSize = "0.72rem";
      coverBtn.style.fontWeight = "800";
      coverBtn.style.color = isCover ? "#fff" : "var(--text)";
      coverBtn.style.background = isCover
        ? "rgba(72, 129, 93, 0.92)"
        : "rgba(255, 255, 255, 0.86)";
      coverBtn.style.cursor = "pointer";
      coverBtn.style.opacity = isPendingDelete ? "0" : "1";
      coverBtn.style.pointerEvents = isPendingDelete ? "none" : "auto";

      coverBtn.addEventListener("click", () => {
        selectedCover = { type: "existing", value: imageUrl };
        renderExistingImages();
        renderImagePreview();
      });

      if (isPendingDelete) {
        const overlay = document.createElement("div");
        overlay.style.position = "absolute";
        overlay.style.inset = "0";
        overlay.style.background = "rgba(40, 40, 40, 0.6)";
        overlay.style.display = "flex";
        overlay.style.flexDirection = "column";
        overlay.style.alignItems = "center";
        overlay.style.justifyContent = "center";
        overlay.style.gap = "0.35rem";
        overlay.style.zIndex = "1";

        const pendingIcon = document.createElement("span");
        pendingIcon.textContent = "×";
        pendingIcon.style.fontSize = "1.35rem";
        pendingIcon.style.fontWeight = "700";
        pendingIcon.style.color = "#fff";
        pendingIcon.style.textShadow = "0 1px 2px rgba(0, 0, 0, 0.5)";

        const pendingText = document.createElement("small");
        pendingText.textContent = "Pendiente de eliminar";
        pendingText.style.fontWeight = "600";
        pendingText.style.color = "#fff";
        pendingText.style.background = "rgba(0, 0, 0, 0.35)";
        pendingText.style.padding = "0.2rem 0.35rem";
        pendingText.style.borderRadius = "4px";
        pendingText.style.textShadow = "0 1px 2px rgba(0, 0, 0, 0.5)";

        const undoBtn = document.createElement("button");
        undoBtn.type = "button";
        undoBtn.className = "btn btn-danger";
        undoBtn.textContent = "Deshacer";
        undoBtn.style.padding = "0.25rem 0.5rem";
        undoBtn.style.fontSize = "0.8rem";
        undoBtn.style.minWidth = "auto";

        undoBtn.addEventListener("click", () => {
          pendingImageDeletes.delete(imageUrl);
          renderExistingImages();
        });

        overlay.appendChild(pendingIcon);
        overlay.appendChild(pendingText);
        overlay.appendChild(undoBtn);
        imageWrapper.appendChild(overlay);
      }

      imageWrapper.appendChild(img);
      imageWrapper.appendChild(coverBtn);
      imageWrapper.appendChild(deleteBtn);
      existingImagesContainer.appendChild(imageWrapper);
    });

    if (deleteImagesLegend) {
      deleteImagesLegend.style.display = pendingImageDeletes.size > 0 ? "block" : "none";
    }
  }

  function renderImagePreview() {
    if (!imagePreview) return;

    imagePreview.innerHTML = "";
    const files = imageFilesInput.files;

    if (files) {
      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        const reader = new FileReader();

        reader.onload = (e) => {
          const previewWrapper = document.createElement("div");
          previewWrapper.style.position = "relative";
          previewWrapper.style.overflow = "hidden";
          previewWrapper.style.border = "2px solid var(--border)";
          previewWrapper.style.borderRadius = "4px";

          const img = document.createElement("img");
          img.src = e.target?.result as string;
          img.style.width = "100%";
          img.style.height = "100px";
          img.style.objectFit = "cover";
          img.style.display = "block";

          const isCover = selectedCover?.type === "upload" && selectedCover.index === i;
          const coverBtn = document.createElement("button");
          coverBtn.type = "button";
          coverBtn.textContent = isCover ? "Portada" : "Usar portada";
          coverBtn.style.position = "absolute";
          coverBtn.style.left = "6px";
          coverBtn.style.bottom = "6px";
          coverBtn.style.padding = "0.25rem 0.45rem";
          coverBtn.style.border = "1px solid rgba(255, 255, 255, 0.7)";
          coverBtn.style.borderRadius = "999px";
          coverBtn.style.fontSize = "0.72rem";
          coverBtn.style.fontWeight = "800";
          coverBtn.style.color = isCover ? "#fff" : "var(--text)";
          coverBtn.style.background = isCover
            ? "rgba(72, 129, 93, 0.92)"
            : "rgba(255, 255, 255, 0.86)";
          coverBtn.style.cursor = "pointer";

          coverBtn.addEventListener("click", () => {
            selectedCover = { type: "upload", index: i };
            renderExistingImages();
            renderImagePreview();
          });

          previewWrapper.appendChild(img);
          previewWrapper.appendChild(coverBtn);
          imagePreview.appendChild(previewWrapper);
        };

        if (file) reader.readAsDataURL(file);
      }
    }
  }

  // Image preview functionality
  imageFilesInput?.addEventListener("change", () => {
    if (selectedCover?.type === "upload") {
      selectedCover = null;
    }
    renderImagePreview();
  });

  // Check if already logged in
  const savedPassword = sessionStorage.getItem("adminPassword");
  if (savedPassword) {
    adminPassword = savedPassword;
    validateAndShowAdminPanel().finally(() => {
      setButtonLoading(loginBtn as HTMLButtonElement | null, false);
      if (passwordInput) passwordInput.disabled = false;
    });
  }

  loginBtn?.addEventListener("click", async () => {
    adminPassword = passwordInput.value;
    if (adminPassword) {
      await validateAndShowAdminPanel();
      setButtonLoading(loginBtn as HTMLButtonElement | null, false);
      if (passwordInput) passwordInput.disabled = false;
    } else {
      showAuthMessage("Por favor ingrese una contraseña", "error");
    }
  });

  logoutBtn?.addEventListener("click", () => {
    adminPassword = "";
    sessionStorage.removeItem("adminPassword");
    if (loginSection && adminPanel) {
      loginSection.style.display = "block";
      adminPanel.style.display = "none";
    }
    if (passwordInput) passwordInput.value = "";
  });

  addDogTab?.addEventListener("click", () => {
    resetDogForm();
    showAdminView("add");
  });

  manageDogsTab?.addEventListener("click", () => {
    resetDogForm();
    showAdminView("manage");
    loadDogs();
  });

  function showAdminPanel() {
    if (loginSection && adminPanel) {
      loginSection.style.display = "none";
      adminPanel.style.display = "block";
    }
    showAdminView("manage");
    loadDogs();
  }

  adminSearch?.addEventListener("input", renderPetsList);
  adminSpeciesFilter?.addEventListener("change", renderPetsList);
  adminStatusFilter?.addEventListener("change", renderPetsList);

  async function validateAndShowAdminPanel() {
    setButtonLoading(loginBtn as HTMLButtonElement | null, true, "Validando...");
    if (passwordInput) passwordInput.disabled = true;

    try {
      const response = await fetch("/api/auth/check", {
        method: "POST",
        headers: {
          "X-Admin-Password": adminPassword,
        },
      });

      if (!response.ok) {
        sessionStorage.removeItem("adminPassword");
        showAuthMessage("Contraseña incorrecta", "error");
        setButtonLoading(loginBtn as HTMLButtonElement | null, false);
        if (passwordInput) passwordInput.disabled = false;
        return;
      }

      sessionStorage.setItem("adminPassword", adminPassword);
      showAuthMessage("", "success");
      showAdminPanel();
      setButtonLoading(loginBtn as HTMLButtonElement | null, false);
      if (passwordInput) passwordInput.disabled = false;
    } catch (error) {
      showAuthMessage("No se pudo validar la contraseña", "error");
    }
  }

  async function optimizeSelectedImages() {
    const imageFiles = imageFilesInput?.files;
    if (!imageFiles || imageFiles.length === 0) return [];

    const clientValidationError = validateImageFiles(imageFiles);
    if (clientValidationError) {
      throw clientValidationError;
    }

    return Promise.all(Array.from(imageFiles).map((file) => optimizeImageSource(file)));
  }

  async function buildDogPayload(formData: FormData, uploadedUrls: string[]) {
    const data: any = {};
    const rawKeptExistingImages = currentDogImages.filter(
      (imageUrl) => !pendingImageDeletes.has(imageUrl),
    );
    const keptExistingImages = await Promise.all(
      rawKeptExistingImages.map((imageUrl) =>
        imageUrl.startsWith("data:image/") ? optimizeImageSource(imageUrl) : imageUrl,
      ),
    );

    formData.forEach((value, key) => {
      if (key === "healthConditions" && value) {
        data[key] = parseCommaSeparated(value as string);
      } else if (key === "images" && value) {
        const urlImages = parseCommaSeparated(value as string);
        data[key] = [...keptExistingImages, ...urlImages, ...uploadedUrls];
      } else if (key === "vaccinated" || key === "sterilized") {
        data[key] = (document.getElementById(key) as HTMLInputElement).checked;
      } else {
        data[key] = value;
      }
    });

    data.vaccinated = (document.getElementById("vaccinated") as HTMLInputElement).checked;
    data.sterilized = (document.getElementById("sterilized") as HTMLInputElement).checked;

    if (!data.images || data.images.length === 0) {
      data.images = [...keptExistingImages, ...uploadedUrls];
    }

    let coverImage = "";
    if (selectedCover?.type === "existing") {
      const coverIndex = rawKeptExistingImages.indexOf(selectedCover.value);
      coverImage = coverIndex >= 0 ? keptExistingImages[coverIndex] || "" : "";
    } else if (selectedCover?.type === "upload") {
      coverImage = uploadedUrls[selectedCover.index] || "";
    }

    if (coverImage) {
      data.images = [coverImage, ...data.images.filter((image: string) => image !== coverImage)];
    }

    if (data.images.length > MAX_IMAGE_COUNT) {
      throw createFormError(
        "too_many_images",
        "Demasiadas imágenes",
        `Cada mascota puede tener hasta ${MAX_IMAGE_COUNT} imágenes.`,
        ["Elimina algunas imágenes actuales o selecciona menos archivos antes de guardar."],
      );
    }

    return data;
  }

  function fillDogForm(dog: any) {
    dogIdInput.value = dog._id;
    (document.getElementById("species") as HTMLSelectElement).value = dog.species || "dog";
    (document.getElementById("name") as HTMLInputElement).value = dog.name;
    (document.getElementById("breed") as HTMLInputElement).value = dog.breed;
    (document.getElementById("approximateBirthDate") as HTMLInputElement).value =
      formatDateInput(dog.approximateBirthDate) || estimateBirthDateFromAge(dog.age);
    (document.getElementById("gender") as HTMLSelectElement).value = dog.gender;
    (document.getElementById("size") as HTMLSelectElement).value = dog.size;
    (document.getElementById("status") as HTMLSelectElement).value = dog.status;
    (document.getElementById("description") as HTMLTextAreaElement).value =
      dog.description;
    (document.getElementById("personality") as HTMLTextAreaElement).value =
      dog.personality || "";
    (document.getElementById("specialCare") as HTMLTextAreaElement).value =
      dog.specialCare || "";
    (document.getElementById("healthConditions") as HTMLInputElement).value =
      dog.healthConditions.join(", ");
    (document.getElementById("vaccinated") as HTMLInputElement).checked =
      dog.vaccinated;
    (document.getElementById("sterilized") as HTMLInputElement).checked =
      dog.sterilized;

    currentDogImages = [...dog.images];
    pendingImageDeletes = new Set();
    selectedCover = currentDogImages[0]
      ? { type: "existing", value: currentDogImages[0] }
      : null;
    renderExistingImages();
    (document.getElementById("images") as HTMLInputElement).value = "";

    if (formTitle) formTitle.textContent = "Editar mascota";
    showAdminView("add");
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function showAuthMessage(message: string, type: "success" | "error") {
    if (authMessage) {
      authMessage.className = type;
      authMessage.textContent = message;
    }
  }

  function showAdminMessage(message: string, type: "success" | "error") {
    if (adminMessage) {
      adminMessage.className = type;
      adminMessage.textContent = message;
      setTimeout(() => {
        adminMessage.textContent = "";
        adminMessage.className = "";
      }, 3000);
    }
  }

  function showErrorModal(error: MascotFormError) {
    if (!errorModal || !errorModalTitle || !errorModalMessage || !errorModalDetails) return;

    errorModalTitle.textContent = error.title;
    errorModalMessage.textContent = error.message;
    errorModalDetails.replaceChildren();

    for (const detail of error.details) {
      const item = document.createElement("li");
      item.textContent = detail;
      errorModalDetails.appendChild(item);
    }

    errorModal.hidden = false;
    errorModalCloseBtn?.focus();
  }

  function hideErrorModal() {
    if (errorModal) errorModal.hidden = true;
  }

  function setSubmitLoading(isLoading: boolean, loadingText = "Guardando...") {
    if (!submitBtn) return;

    setButtonLoading(submitBtn, isLoading, loadingText);
  }

  errorModalCloseBtn?.addEventListener("click", hideErrorModal);
  errorModal?.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    if (target.dataset.modalClose !== undefined) hideErrorModal();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && errorModal && !errorModal.hidden) {
      hideErrorModal();
    }
  });

  function renderPetsList() {
    const pets = getFilteredPets();

    if (dogsList) {
      dogsList.replaceChildren();

      pets.forEach((pet: any) => {
        const item = document.createElement("li");

        const details = document.createElement("div");
        const name = document.createElement("strong");
        name.textContent = pet.name;

        const meta = document.createElement("span");
        meta.className = "admin-pet-meta";
        meta.textContent = `${getSpeciesLabel(pet.species)} · ${pet.breed}`;

        const status = document.createElement("span");
        status.className = `dog-status status-${pet.status}`;
        status.textContent = getStatusLabel(pet.status);

        details.append(name, meta, status);

        const actions = document.createElement("div");
        actions.className = "dog-actions";

        const editButton = document.createElement("button");
        editButton.className = "btn";
        editButton.dataset.action = "edit";
        editButton.dataset.id = pet._id;
        editButton.textContent = "Editar";

        const deleteButton = document.createElement("button");
        deleteButton.className = "btn btn-danger";
        deleteButton.dataset.action = "delete";
        deleteButton.dataset.id = pet._id;
        deleteButton.textContent = "Eliminar";

        actions.append(editButton, deleteButton);
        item.append(details, actions);
        dogsList.appendChild(item);
      });

      if (pets.length === 0) {
        const item = document.createElement("li");
        item.className = "admin-empty-row";
        item.textContent = "No hay mascotas que coincidan con esos filtros.";
        dogsList.appendChild(item);
      }
    }
  }

  async function loadDogs() {
    renderListLoading("Cargando mascotas...");
    setListFiltersDisabled(true);

    try {
      const response = await fetch("/api/pets");
      if (!response.ok) {
        const errorData = await response.json().catch(() => null);
        throw new Error(errorData?.error || "Error al cargar las mascotas");
      }

      const dogs = await response.json();
      if (!Array.isArray(dogs)) {
        throw new Error("Formato de respuesta inválido");
      }

      allPets = dogs;
      renderPetsList();
    } catch (error) {
      const message = error instanceof Error ? error.message : "Error al cargar las mascotas";
      showAdminMessage(message, "error");
    } finally {
      setListFiltersDisabled(false);
    }
  }

  dogForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const requiredFieldsError = validateRequiredFields(dogForm);
    if (requiredFieldsError) {
      showErrorModal(requiredFieldsError);
      return;
    }

    const imageUrls = parseCommaSeparated(
      (document.getElementById("images") as HTMLInputElement).value,
    );
    const imageUrlError = validateImageUrls(imageUrls);
    if (imageUrlError) {
      showErrorModal(imageUrlError);
      return;
    }

    const formData = new FormData(dogForm);
    let uploadedUrls: string[] = [];

    setSubmitLoading(true, "Optimizando imágenes...");

    try {
      uploadedUrls = await optimizeSelectedImages();
    } catch (error) {
      const mascotError =
        error && typeof error === "object" && "code" in error
          ? (error as MascotFormError)
          : createNetworkError("upload");
      showErrorModal(mascotError);
      setSubmitLoading(false);
      return;
    }

    let data: any;
    try {
      data = await buildDogPayload(formData, uploadedUrls);
    } catch (error) {
      const mascotError =
        error && typeof error === "object" && "code" in error
          ? (error as MascotFormError)
          : createNetworkError("save");
      showErrorModal(mascotError);
      setSubmitLoading(false);
      return;
    }

    const dogId = dogIdInput.value;
    const url = dogId ? `/api/pets/${dogId}` : "/api/pets";
    const method = dogId ? "PUT" : "POST";
    setSubmitLoading(true, "Guardando...");

    try {
      const response = await fetch(url, {
        method,
        headers: getAuthHeaders(true),
        body: JSON.stringify(data),
      });

      if (response.ok) {
        showAdminMessage(
          dogId ? "Mascota actualizada correctamente" : "Mascota agregada correctamente",
          "success",
        );
        resetDogForm();
        showAdminView("manage");
        await loadDogs();
      } else {
        const errorBody = await response.json().catch(() => null);
        showErrorModal(parseApiError(response.status, errorBody?.error, "save"));
      }
    } catch {
      showErrorModal(createNetworkError("save"));
    } finally {
      setSubmitLoading(false);
    }
  });

  cancelBtn?.addEventListener("click", () => {
    resetDogForm();
    showAdminView("manage");
  });

  async function editDog(id: string, button?: HTMLButtonElement) {
    setButtonLoading(button, true, "Cargando...");

    try {
      const response = await fetch(`/api/pets/${id}`);

      if (!response.ok) {
        const errorBody = await response.json().catch(() => null);
        showErrorModal(parseApiError(response.status, errorBody?.error, "load"));
        return;
      }

      const dog = await response.json();
      fillDogForm(dog);
    } catch {
      showErrorModal(createNetworkError("load"));
    } finally {
      setButtonLoading(button, false);
    }
  }

  async function deleteDog(id: string, button?: HTMLButtonElement) {
    if (!confirm("¿Estás seguro de que quieres eliminar esta mascota?")) {
      return;
    }

    setButtonLoading(button, true, "Eliminando...");

    try {
      const response = await fetch(`/api/pets/${id}`, {
        method: "DELETE",
        headers: getAuthHeaders(),
      });

      if (response.ok) {
        showAdminMessage("Mascota eliminada correctamente", "success");
        await loadDogs();
      } else {
        const error = await response.json();
        showAdminMessage(error.error || "Error al eliminar la mascota", "error");
      }
    } catch (error) {
      showAdminMessage("Error al eliminar la mascota", "error");
    } finally {
      setButtonLoading(button, false);
    }
  }

  dogsList?.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement;
    const button = target.closest("button[data-action][data-id]") as HTMLButtonElement;
    if (!button) return;

    const action = button.dataset.action;
    const id = button.dataset.id;
    if (!id) return;

    if (action === "edit") {
      await editDog(id, button);
    } else if (action === "delete") {
      await deleteDog(id, button);
    }
  });
</script>
